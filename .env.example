# ============================================
# BetterOrmoc Environment Variables
# ============================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!

# ============================================
# SUPABASE DATABASE
# ============================================
# For local development, use Supabase CLI (supabase start)
# For production, get these from your Supabase project settings

# Local Development (from `supabase start`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_local_supabase_anon_key

# Production (from Supabase Dashboard > Project Settings > API)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_production_anon_key

# ============================================
# ERROR TRACKING (SENTRY)
# ============================================
# Sign up at https://sentry.io
# Get DSN from: Settings > Projects > [Your Project] > Client Keys (DSN)

NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn@sentry.io/your_project_id
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# Optional: Sentry Configuration
# SENTRY_ORG=your-org-name
# SENTRY_PROJECT=betterormoc

# ============================================
# CONTACT FORM (RESEND)
# ============================================
# Sign up at https://resend.com (Free tier: 100 emails/day)
# Get API key from: https://resend.com/api-keys

RESEND_API_KEY=re_xxxxxxxxxxxxx
CONTACT_EMAIL=contact@ormoc.gov.ph

# Optional: Custom sender domain (requires domain verification)
# RESEND_FROM_EMAIL=noreply@betterormoc.org

# ============================================
# ANALYTICS & MONITORING
# ============================================
# Optional: Vercel Analytics (automatically enabled on Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_analytics_id

# Optional: Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# RATE LIMITING (OPTIONAL)
# ============================================
# For production rate limiting, use Upstash Redis
# Sign up at https://upstash.com (Free tier: 10,000 commands/day)

# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_redis_token

# ============================================
# EXTERNAL APIs (OPTIONAL)
# ============================================
# Weather API - Open-Meteo (No API key required, free)
# Currency API - ExchangeRate-API (No API key required for basic usage)

# Optional: If using alternative APIs
# OPENWEATHER_API_KEY=your_openweather_key
# EXCHANGERATE_API_KEY=your_exchangerate_key

# ============================================
# DEVELOPMENT & DEPLOYMENT
# ============================================
# Node Environment (automatically set by Next.js)
# NODE_ENV=development

# Optional: Custom port for dev server
# PORT=3000

# Optional: Enable Next.js debug mode
# DEBUG=true

# ============================================
# SECURITY
# ============================================
# Optional: reCAPTCHA (for production spam protection)
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key
# RECAPTCHA_SECRET_KEY=your_secret_key

# Optional: CORS allowed origins (comma-separated)
# ALLOWED_ORIGINS=https://betterormoc.org,https://www.betterormoc.org

# ============================================
# FEATURE FLAGS (OPTIONAL)
# ============================================
# Enable/disable features in production

# FEATURE_SEARCH_ENABLED=true
# FEATURE_MAPS_ENABLED=true
# FEATURE_MULTILINGUAL_ENABLED=false

# ============================================
# NOTES
# ============================================
# 1. All NEXT_PUBLIC_* variables are exposed to the browser
# 2. Never put sensitive keys in NEXT_PUBLIC_* variables
# 3. Use different values for development, staging, and production
# 4. Restart dev server after changing environment variables
# 5. For Vercel deployment, set these in Project Settings > Environment Variables